{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://76.13.143.199:3000/api/:path*"
    },
    {
      "source": "/socket.io/",
      "destination": "http://76.13.143.199:3000/socket.io/"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "http://76.13.143.199:3000/socket.io/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
