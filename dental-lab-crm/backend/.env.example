# ============================================================================
# Backend environment variables — copy to .env (dev) or .env.production (VPS)
# ============================================================================

# JWT
JWT_SECRET=change-me-jwt-secret
JWT_REFRESH_EXPIRATION=7d

# Google OAuth (not yet active in DEV mode)
GOOGLE_CLIENT_ID=placeholder
GOOGLE_CLIENT_SECRET=placeholder

# Frontend URL (used in OAuth redirects, emails)
FRONTEND_URL=http://localhost:5173

# Backend
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dental_lab_crm

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173

# File upload
UPLOAD_PATH=./uploads

# ============================================================================
# AGENT PACK — Vision Import
# ============================================================================
# Anthropic Claude Vision — primary (https://console.anthropic.com/)
ANTHROPIC_API_KEY=
# Google Gemini Vision — fallback (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# ============================================================================
# AGENT PACK — WhatsApp Cloud API
# ============================================================================
# From Meta Business → WhatsApp Manager → API setup
META_WA_PHONE_NUMBER_ID=
META_WA_ACCESS_TOKEN=
META_WA_BUSINESS_ACCOUNT_ID=
# Random string YOU choose. Meta will GET ?hub.verify_token=... on webhook registration.
META_WA_WEBHOOK_VERIFY_TOKEN=

# Shadow mode: false = simulate only, true = really send via Meta API
WHATSAPP_AUTO_SEND=false
# Phone number (E.164, no '+') to receive shadow copies (e.g. your mobile)
WHATSAPP_SHADOW_RECIPIENT=

# === INVOICE4U (Fase C — Israeli fiscal invoicing via SOAP) ===
INVOICE4U_WSDL_URL=https://apiqa.invoice4u.co.il/Services/ApiService.svc?singleWsdl
INVOICE4U_TOKEN=
INVOICE4U_DRY_RUN=false
INVOICE4U_AUTO_SYNC=false
INVOICE4U_DEFAULT_TAX_RATE=18
