# Production Environment Variables - VPS Deploy

# JWT Configuration
JWT_SECRET=dental-lab-crm-secure-jwt-key-2026-VPS

# Google OAuth Credentials (NOT CONFIGURED YET)
GOOGLE_CLIENT_ID=placeholder
GOOGLE_CLIENT_SECRET=placeholder

# Frontend URL (Vercel)
FRONTEND_URL=https://gestionale-shen3d.vercel.app

# Backend Port
PORT=3000

# Database URL (PostgreSQL inside Docker network)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/dental_lab_crm

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# CORS Origins
CORS_ORIGINS=https://gestionale-shen3d.vercel.app,https://api.shen3d.com,http://76.13.143.199,http://localhost:5173

# File Upload Path
UPLOAD_PATH=./uploads

# Environment
NODE_ENV=production

# ============================================================================
# AGENT PACK — Vision Import (Fase 2)
# ============================================================================
# Anthropic Claude Vision (primary, get key from console.anthropic.com)
ANTHROPIC_API_KEY=
# Google Gemini Vision (fallback, get key from aistudio.google.com/apikey)
GEMINI_API_KEY=

# ============================================================================
# AGENT PACK — WhatsApp Cloud API (Fase 3+4)
# ============================================================================
# Meta Cloud API credentials (get from business.facebook.com → WhatsApp Manager)
META_WA_PHONE_NUMBER_ID=
META_WA_ACCESS_TOKEN=
META_WA_BUSINESS_ACCOUNT_ID=
# Random secret token, you choose it, used to validate Meta webhook calls
META_WA_WEBHOOK_VERIFY_TOKEN=

# Shadow mode: false = NON invia messaggi reali, logga solo (fase test).
# Quando vuoi andare live: WHATSAPP_AUTO_SEND=true + docker compose up --build -d backend
WHATSAPP_AUTO_SEND=false
# Numero E.164 (senza '+') a cui mandare le copie in shadow mode (es. il tuo cellulare)
WHATSAPP_SHADOW_RECIPIENT=

# ============================================================================
# INVOICE4U (Fase C — fatturazione fiscale israeliana via SOAP)
# ============================================================================
# Staging URL (test ufficiale invoice4u — documenti senza valore fiscale):
INVOICE4U_WSDL_URL=https://apiqa.invoice4u.co.il/Services/ApiService.svc?singleWsdl
# Production: https://api.invoice4u.co.il/Services/ApiService.svc?singleWsdl
# Token GUID generato da invoice4u → Settings → API → Generate
INVOICE4U_TOKEN=
# Sicurezza extra: se true, logga solo l'XML che AVREBBE mandato (no chiamata reale)
INVOICE4U_DRY_RUN=false
# Se false, l'emissione documenti NON chiama invoice4u (resta solo locale).
# Quando setti true, anche staging riceve davvero le chiamate SOAP.
INVOICE4U_AUTO_SYNC=false
# Tax rate default % usato se SystemSettings.default_tax_rate non è settato
INVOICE4U_DEFAULT_TAX_RATE=18

# === INVOICE4U MODE (Fase C) ===
# mock = dati fake (sicuro). staging = sandbox invoice4u. production = fiscale ufficiale.
INVOICE4U_MODE=mock
