# ===========================================
# DENTAL LAB CRM - Environment Configuration
# ===========================================

# Application
NODE_ENV=development
APP_NAME=Dental Lab CRM
APP_URL=http://localhost:5173

# Backend
BACKEND_PORT=3000
BACKEND_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dental_lab_crm?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# File Storage (S3 Compatible - Cloudflare R2 / AWS S3 / MinIO)
STORAGE_PROVIDER=local
STORAGE_ENDPOINT=
STORAGE_REGION=auto
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=dental-lab-files
STORAGE_PUBLIC_URL=

# Email (SendGrid)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@shen3d.com
SENDGRID_FROM_NAME=Shen3D Lab

# WhatsApp (Twilio) - Future
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# Sentry (Error Tracking)
SENTRY_DSN=

# Frontend
VITE_API_URL=http://localhost:3000/api
VITE_SOCKET_URL=http://localhost:3000
VITE_GOOGLE_CLIENT_ID=your-google-client-id
