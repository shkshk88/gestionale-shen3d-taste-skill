# Production Environment Variables - VPS Backend

# API Backend URL (VPS IP port 3000 - HTTP until domain + SSL added)
VITE_API_URL=/api

# Disable auto-login for production (forces real authentication)
VITE_DISABLE_AUTO_LOGIN=true

# Application name
VITE_APP_NAME=Shen3D Dental Lab CRM

# Support contact
VITE_SUPPORT_EMAIL=support@shen3d.com
