# Production Environment Variables - VPS Backend

# API Backend URL (VPS via Nginx HTTPS — bypasses Vercel proxy size limit)
VITE_API_URL=https://api.shen3d.com/api

# WebSocket URL — same HTTPS endpoint, supports WebSocket upgrade natively
VITE_SOCKET_URL=https://api.shen3d.com

# Disable auto-login for production (forces real authentication)
VITE_DISABLE_AUTO_LOGIN=true

# Application name
VITE_APP_NAME=Shen3D Dental Lab CRM

# Support contact
VITE_SUPPORT_EMAIL=support@shen3d.com
