# Production Environment Variables for Railway Deploy

# API Backend URL (Railway backend - update after first deploy)
VITE_API_URL=https://shen3d-backend.up.railway.app/api

# Disable auto-login for production (forces real authentication)
VITE_DISABLE_AUTO_LOGIN=true

# Application name
VITE_APP_NAME=Shen3D Dental Lab CRM

# Support contact
VITE_SUPPORT_EMAIL=support@shen3d.com
